# ═══════════════════════════════════════════════════════════════
# PRODUCTION ENVIRONMENT VARIABLES
# Property Rental & Booking Platform - Server
# ═══════════════════════════════════════════════════════════════

# ─── SERVER CONFIGURATION ───────────────────────────────────────
NODE_ENV=production
PORT=5000

# ─── MONGODB ATLAS CONNECTION ───────────────────────────────────
# Get your connection string from: https://cloud.mongodb.com
# Format: mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/database
# Replace <password> with your actual database user password

MONGODB_URI=mongodb+srv://property-rental-admin:YOUR_PASSWORD_HERE@cluster0.xxxxx.mongodb.net/property-rental?retryWrites=true&w=majority

# ─── JWT AUTHENTICATION ───────────────────────────────────────────
# Generate a secure random string (minimum 32 characters)
# macOS/Linux: openssl rand -base64 32
# Windows: Use https://www.uuidgenerator.net/api/guid

JWT_SECRET=CHANGE_THIS_GENERATE_A_SECURE_32_CHAR_KEY

# ─── STRIPE PAYMENT GATEWAY ────────────────────────────────────────
# Get your keys from: https://dashboard.stripe.com/apikeys
# Test mode key starts with: sk_test_
# Live mode key starts with: sk_live_

STRIPE_SECRET_KEY=sk_test_YOUR_STRIPE_SECRET_KEY_HERE

# ─── FRONTEND URL (CORS) ────────────────────────────────────────────
# Update this with your deployed frontend URL
# Required for CORS configuration

CLIENT_URL=https://your-frontend-domain.vercel.app

# ─── ADMIN ACCOUNT (for database seeding) ────────────────────────────
# IMPORTANT: Change these default credentials in production!

ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=CHANGE_THIS_TO_A_SECURE_PASSWORD

# ─── OPTIONAL CONFIGURATIONS ─────────────────────────────────────────
# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
