# Production Environment Variables Template
# Copy this file to .env.production.local and fill in your values

# Server Configuration
NODE_ENV=production
PORT=5000

# MongoDB Atlas Connection
# Get your connection string from: https://www.mongodb.com/cloud/atlas
MONGODB_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@cluster.mongodb.net/property-rental?retryWrites=true&w=majority

# JWT Authentication
# Generate a secure random string (min 32 characters)
# Use: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Stripe Payment Gateway
# Get your keys from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here

# Frontend URL
# Update this with your deployed frontend URL
CLIENT_URL=https://your-frontend.vercel.app

# Admin Account (for database seeding)
# IMPORTANT: Change these default credentials in production!
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=your-secure-admin-password-here

# Optional: Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Optional: Logging
LOG_LEVEL=info
