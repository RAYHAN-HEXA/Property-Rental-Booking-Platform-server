# Stripe Configuration Example
# Add these to your Vercel environment variables or local .env file

# ═══════════════════════════════════════════════════════════════
# STRIPE PAYMENT GATEWAY CONFIGURATION
# ═══════════════════════════════════════════════════════════════

# Stripe Secret Key (Required)
# Get from: https://dashboard.stripe.com/apikeys
# Test mode starts with: sk_test_
# Live mode starts with: sk_live_
STRIPE_SECRET_KEY=sk_test_51YourStripeSecretKeyHere

# Stripe Webhook Secret (Optional but Recommended)
# Get from: https://dashboard.stripe.com/webhooks
# After creating webhook endpoint
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Stripe Publishable Key (For frontend reference)
# Get from: https://dashboard.stripe.com/apikeys
# Test mode starts with: pk_test_
# Live mode starts with: pk_live_
# Note: This should be used in frontend, not server
STRIPE_PUBLISHABLE_KEY=pk_test_51YourStripePublishableKeyHere

# ═══════════════════════════════════════════════════════════════
# TESTING CONFIGURATION (Development Only)
# ═══════════════════════════════════════════════════════════════

# Enable test mode
STRIPE_TEST_MODE=true

# Test webhook signing secret (local testing with Stripe CLI)
STRIPE_TEST_WEBHOOK_SECRET=whsec_test_only_secret

# ═══════════════════════════════════════════════════════════════
# PAYMENT CONFIGURATION
# ═══════════════════════════════════════════════════════════════

# Minimum payment amount (in cents, default: 100 = $1.00)
STRIPE_MIN_AMOUNT=100

# Maximum payment amount (in cents, default: 99999999 = $999,999.99)
STRIPE_MAX_AMOUNT=99999999

# Payment description for receipts
PAYMENT_DESCRIPTION="Property Rental Booking Payment"

# ═══════════════════════════════════════════════════════════════
# REFUND CONFIGURATION
# ═══════════════════════════════════════════════════════════════

# Allow automatic refunds (true/false)
ALLOW_AUTOMATIC_REFUNDS=true

# Refund time limit in hours (0 = no limit)
REFUND_TIME_LIMIT_HOURS=168

# ═══════════════════════════════════════════════════════════════
# SECURITY NOTES
# ═══════════════════════════════════════════════════════════════

# ⚠️ IMPORTANT SECURITY NOTES:
# 1. NEVER commit these keys to git
# 2. ALWAYS use environment variables
# 3. NEVER share secret keys with frontend
# 4. Only use PUBLISHABLE_KEY in frontend
# 5. Rotate keys regularly
# 6. Use webhook signatures to verify events

# ═══════════════════════════════════════════════════════════════
# QUICK SETUP
# ═══════════════════════════════════════════════════════════════

# 1. Get your keys: https://dashboard.stripe.com/apikeys
# 2. Copy SECRET_KEY to STRIPE_SECRET_KEY
# 3. Copy PUBLISHABLE_KEY to frontend .env
# 4. Set up webhook: https://dashboard.stripe.com/webhooks
# 5. Copy webhook secret to STRIPE_WEBHOOK_SECRET
