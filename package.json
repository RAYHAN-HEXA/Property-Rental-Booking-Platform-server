{
  "name": "property-rental-server",
  "version": "1.0.0",
  "description": "Backend API for Property Rental & Booking Platform",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "seed": "node src/config/seed.js",
    "setup": "node scripts/setup-env.js",
    "deploy": "vercel",
    "deploy:prod": "vercel --prod",
    "logs": "vercel logs",
    "env:pull": "vercel env pull .env.local",
    "env:push": "vercel env push"
  },
  "keywords": [
    "property",
    "rental",
    "booking",
    "express",
    "mongodb"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^9.7.4",
    "stripe": "^16.12.0"
  }
}
